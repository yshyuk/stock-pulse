# Copy to `.env` and fill in. `.env` is gitignored.
# On the Mac Mini these are injected via the launchd plist's <EnvironmentVariables>.

# ── Profile ──────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Database (prod / MySQL) ──────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/stockpulse?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=stockpulse
DB_PASSWORD=change-me

# ── Notification: Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notification: Discord ────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Report output ────────────────────────────────────────────────────────────
STOCKPULSE_REPORT_DIR=/Users/Shared/stock-pulse/reports
STOCKPULSE_RUN_HOUR=6

# ── Future: second-stage Claude analysis (unused today) ──────────────────────
ANTHROPIC_API_KEY=
